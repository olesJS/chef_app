<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="15.0" styleClass="dialog-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.lpnu.chef_app.controller.ProductDialogController">

<stylesheets>
    <URL value="@../styles/dialogs.css" />
</stylesheets>

<padding>
    <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
</padding>

<Label fx:id="titleLabel" text="Додати новий продукт" styleClass="dialog-header"/>

<GridPane hgap="10.0" vgap="15.0">
    <columnConstraints>
        <ColumnConstraints prefWidth="120.0" />
        <ColumnConstraints hgrow="ALWAYS" />
    </columnConstraints>

    <children>
        <Label text="Назва:" GridPane.rowIndex="0" />
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="modern-input"/>

        <Label text="Категорія:" GridPane.rowIndex="1" />
        <ComboBox fx:id="typeComboBox" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="modern-combo"/>

        <Label text="Ккал/100г:" GridPane.rowIndex="2" />
        <TextField fx:id="kcalField" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="modern-input"/>

        <Label text="Білки / Жири / Вугл:" GridPane.rowIndex="3" />
        <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <TextField fx:id="pField" promptText="Б" styleClass="modern-input, input-small"/>
            <TextField fx:id="fField" promptText="Ж" styleClass="modern-input, input-small"/>
            <TextField fx:id="cField" promptText="В" styleClass="modern-input, input-small"/>
        </HBox>
    </children>
</GridPane>

<Separator styleClass="dialog-separator"/>

<StackPane fx:id="dynamicContentArea" prefHeight="50.0">
    <children>
        <VBox fx:id="vegetableExtraBox" spacing="10.0" visible="false">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label fx:id="extraLabel" text="Показник (%):" />
                <TextField fx:id="extraField" />
            </HBox>
        </VBox>
        <VBox fx:id="dressingExtraBox" spacing="10.0" visible="false">
            <CheckBox fx:id="fatBasedCheckBox" text="На жирній основі" />
        </VBox>
        <VBox fx:id="toppingExtraBox" spacing="10.0" visible="false">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Алерген:" />
                <ComboBox fx:id="allergenComboBox" prefWidth="150.0" />
                <CheckBox fx:id="crunchyCheckBox" text="Хрусткий" />
            </HBox>
        </VBox>
    </children>
</StackPane>

<HBox alignment="CENTER_RIGHT" spacing="10.0">
    <Button onAction="#handleCancel" text="Скасувати" styleClass="btn, btn-default"/>
    <Button onAction="#handleSave" text="Зберегти" styleClass="btn, btn-success"/>
</HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="0.0" style="-fx-background-color: #f4f7f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.lpnu.chef_app.controller.ProductController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <padding>
            <Insets left="30.0" right="30.0" />
        </padding>
        <VBox alignment="CENTER_LEFT">
            <Label style="-fx-text-fill: #2c3e50;" text="Склад продуктів">
                <font>
                    <Font name="System Bold" size="26.0" />
                </font>
            </Label>
            <Label style="-fx-text-fill: #7f8c8d;" text="Керування базою продуктів" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Filter panel -->
        <HBox alignment="CENTER" spacing="10.0">
            <TextField fx:id="searchField"
                       prefWidth="200.0"
                       promptText="Пошук за назвою..."
                       style="-fx-background-radius: 4; -fx-border-color: #dcdde1; -fx-border-radius: 4;" />

            <ComboBox fx:id="sortComboBox" prefWidth="150.0" promptText="Сортувати за..."
                      style="-fx-background-radius: 4; -fx-border-color: #dcdde1; -fx-border-radius: 4;" />

            <ComboBox fx:id="categoryFilter"
                      prefWidth="150.0"
                      style="-fx-background-radius: 4; -fx-border-color: #dcdde1; -fx-border-radius: 4;" />
        </HBox>

        <Button fx:id="btnAdd" onAction="#handleAddAction" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Додати продукт">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </HBox>

    <!-- Main content -->
    <VBox spacing="20.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <!-- Table -->
        <TableView fx:id="productTable" style="-fx-background-radius: 10; -fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colName" prefWidth="180.0" text="Продукт" />
                <TableColumn fx:id="colType" prefWidth="130.0" text="Категорія" />
                <TableColumn fx:id="colKcal" prefWidth="90.0" text="Ккал" />
                <TableColumn fx:id="colProteins" prefWidth="80.0" text="Білки" />
                <TableColumn fx:id="colFats" prefWidth="80.0" text="Жири" />
                <TableColumn fx:id="colCarbs" prefWidth="80.0" text="Вугл." />
                <TableColumn fx:id="colDetails" prefWidth="200.0" text="Характеристики" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <!-- Footer panel -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Виберіть рядок для редагування або видалення" style="-fx-text-fill: #95a5a6; -fx-font-style: italic;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnEdit" onAction="#handleEditAction" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Редагувати">
                <padding>
                    <Insets bottom="8.0" left="25.0" right="25.0" top="8.0" />
                </padding>
            </Button>
            <Button fx:id="btnDelete" onAction="#handleDeleteAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Видалити">
                <padding>
                    <Insets bottom="8.0" left="25.0" right="25.0" top="8.0" />
                </padding>
            </Button>
        </HBox>
    </VBox>
</VBox>
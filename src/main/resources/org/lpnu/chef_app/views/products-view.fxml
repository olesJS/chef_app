<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="0.0" styleClass="root-container"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.lpnu.chef_app.controller.ProductController">

    <stylesheets>
        <URL value="@../styles/products-view.css" />
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" prefHeight="90.0" spacing="20.0" styleClass="header-panel">
        <padding>
            <Insets left="30.0" right="30.0" />
        </padding>
        <VBox alignment="CENTER_LEFT">
            <Label styleClass="main-title" text="Склад продуктів" />
            <Label styleClass="subtitle" text="Керування базою продуктів" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Filter panel -->
        <HBox alignment="CENTER" spacing="12.0">
            <TextField fx:id="searchField" prefWidth="200.0" promptText="Пошук за назвою..." styleClass="modern-input" />
            <ComboBox fx:id="sortComboBox" prefWidth="150.0" promptText="Сортувати за..." styleClass="modern-combo" />
            <ComboBox fx:id="categoryFilter" prefWidth="150.0" styleClass="modern-combo" />
        </HBox>

        <Button fx:id="btnAdd" onAction="#handleAddAction" styleClass="btn, btn-add" text="+ Додати продукт" />
    </HBox>

    <!-- Main content -->
    <VBox spacing="20.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <!-- Table -->
        <TableView fx:id="productTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" styleClass="column-centered" />
                <TableColumn fx:id="colName" prefWidth="180.0" text="Продукт" />
                <TableColumn fx:id="colType" prefWidth="130.0" text="Категорія" />
                <TableColumn fx:id="colKcal" prefWidth="90.0" text="Ккал" />
                <TableColumn fx:id="colProteins" prefWidth="80.0" text="Білки" />
                <TableColumn fx:id="colFats" prefWidth="80.0" text="Жири" />
                <TableColumn fx:id="colCarbs" prefWidth="80.0" text="Вугл." />
                <TableColumn fx:id="colDetails" prefWidth="200.0" text="Характеристики" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <!-- Footer panel -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Виберіть рядок для редагування або видалення" styleClass="hint-text" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnEdit" onAction="#handleEditAction" styleClass="btn, btn-edit" text="Редагувати" />
            <Button fx:id="btnDelete" onAction="#handleDeleteAction" styleClass="btn, btn-delete" text="Видалити" />
        </HBox>
    </VBox>
</VBox>